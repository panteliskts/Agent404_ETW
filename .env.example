ENTSOE_API_KEY=your_entsoe_security_token_here

# ── Authentication ────────────────────────────────────────────────────────────
# Local application login.  Development defaults are admin/admin/admin.
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=change-this-password
# Role for the local user: viewer | operator | admin
APP_AUTH_ROLE=admin
# Optional: store a PBKDF2 hash instead of the plain password.
# Generate with: python -c "from api.security import password_hash_for_env; print(password_hash_for_env('yourpassword'))"
# APP_AUTH_PASSWORD_HASH=

# Use a long random value in real deployments.  If omitted, a temporary key is
# generated at startup and existing sessions expire when the API restarts.
APP_SECRET_KEY=change-this-to-a-long-random-secret

# ── AES-256 encryption key (data at rest) ────────────────────────────────────
# Generate with: python -c "from api.encryption import generate_key; print(generate_key())"
APP_ENCRYPTION_KEY=

# ── Browser / API security boundaries ────────────────────────────────────────
APP_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
APP_ALLOWED_HOSTS=127.0.0.1,localhost
APP_COOKIE_SECURE=false

# ── Rate limits ───────────────────────────────────────────────────────────────
APP_RATE_LIMIT_REQUESTS=240
APP_RATE_LIMIT_WINDOW_SECONDS=60
APP_LOGIN_RATE_LIMIT_REQUESTS=8
APP_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ── OAuth 2.0 / OIDC (enterprise SSO) ────────────────────────────────────────
# Leave blank to disable SSO; users will log in with username/password only.

# Microsoft Entra ID (Azure AD)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Common OIDC settings
APP_PUBLIC_URL=https://api.bess.example.com
APP_FRONTEND_URL=https://bess.example.com
# Comma-separated list of permitted email domains (leave blank to allow all).
OIDC_ALLOWED_DOMAINS=example.com
# Role assigned to SSO users: viewer | operator | admin
OIDC_DEFAULT_ROLE=viewer
